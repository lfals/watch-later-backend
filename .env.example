PORT=3000
DATABASE_URL=postgres://watch_later:watch_later@localhost:5432/watch_later
TEST_DATABASE_URL=postgres://watch_later:watch_later@localhost:5432/watch_later_test
REDIS_URL=redis://localhost:6379
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
LOCAL_MODEL_TIMEOUT_MS=120000
TESSERACT_COMMAND=tesseract
OCR_LANGUAGES=eng
OCR_TIMEOUT_MS=5000
OCR_CONCURRENCY=2
WHISPER_COMMAND=whisper-cli
# Optional whisper.cpp model. When absent, identification still uses frames, OCR and metadata.
WHISPER_MODEL_PATH=
CLERK_JWT_KEY=
CLERK_SECRET_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
TMDB_API_TOKEN=
ALLOW_DEV_AUTH=false
ADMIN_CLERK_USER_IDS=
ADMIN_ORIGINS=http://localhost:5173
SCRAPER_ENABLED=true
SCRAPER_BROWSER_FALLBACK=true
SCRAPER_YTDLP_FALLBACK=true
IDENTIFICATION_PIPELINE_VERSION=local-v1
IDENTIFICATION_CACHE_TTL_DAYS=180
